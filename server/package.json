{
  "name": "groundcheck",
  "version": "0.2.0",
  "description": "The grounding check agents run before they commit to an answer — an MCP server that verifies a factual claim against live sources and returns a verdict, confidence, and citations.",
  "type": "module",
  "bin": { "groundcheck": "dist/server.js" },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["mcp", "model-context-protocol", "fact-check", "grounding", "hallucination", "ai-agents", "claude"],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": { "node": ">=18" }
}
